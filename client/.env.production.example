# Environment Variables for Netlify Deployment

# Copy these to Netlify dashboard:
# Site settings → Environment variables → Add variable

# Backend API URL (update after deploying backend to Render)
REACT_APP_API_URL=https://your-backend-url.onrender.com

# Example for local development:
# REACT_APP_API_URL=http://localhost:5000

# Note: After you deploy backend to Render, come back and update this URL
# Then redeploy the frontend on Netlify
